    sha256 = "cf0137d6961785c34926f879b7a5b5fa0371ab0d6e2959e390e2f00b46165ce9",
    strip_prefix = "nvim-macos-arm64",
    urls = ["https://github.com/neovim/neovim/releases/download/v0.12.0/nvim-macos-arm64.tar.gz"],
)

http_archive(
    name = "neovim_macos_x86_64",
    build_file_content = NEOVIM_BUILD_FILE_CONTENT,
    sha256 = "309b3252a04bf8e4043389d3ea9bbb94e17becea2cde74f11f948b4775bbe3d4",
    strip_prefix = "nvim-macos-x86_64",
    urls = ["https://github.com/neovim/neovim/releases/download/v0.12.0/nvim-macos-x86_64.tar.gz"],
